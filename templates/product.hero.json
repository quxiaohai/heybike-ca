            "heading_size": "text-lg-2xl",
            "text": "<p>Horizon’s 750W hub motor (peak 1200W) and 80 N·m torque empower riders to conquer any terrain with strong power and quick acceleration.<br/></p>",
            "button_label": "",
            "button_link": "",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
