            "image_ratio": "adapt",
            "video_url": "",
            "description": "",
            "enable_video_autoplay": false,
            "enable_video_looping": false,
            "heading": "Shimano 9-Speed",
            "heading_size": "text-lg-2xl",
            "text": "<p>Embrace the precision of Shimano 9-speed gear shift system, delivering seamless transitions that empower your control on both steep ascents and thrilling descents. When paired with Hero's potent motor, experience the ultimate in gear versatility and confident maneuverability.<br/></p>",
            "button_label": "",
            "button_link": "",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "column_qUKjhQ": {
