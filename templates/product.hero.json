            "video_url": "",
            "description": "",
            "enable_video_autoplay": false,
            "enable_video_looping": false,
            "heading": "Full Suspension",
            "heading_size": "text-lg-2xl",
            "text": "<p>HERO's full suspension ensures a comfortable, luxurious ride on challenging terrain with hydraulic front fork shock absorption and rear suspension. Enjoy superior shock absorption and precise handling for conquering every challenge in comfort.<br/></p>",
            "button_label": "",
            "button_link": "",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
