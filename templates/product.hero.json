            "image": "shopify://shop_images/d7fc7e9e7c11bc02608ae4ef643324bb.jpg",
            "image_ratio": "adapt",
            "video_url": "",
            "description": "",
            "enable_video_autoplay": false,
            "enable_video_looping": false,
            "heading": "Hydraulic Disc Brakes",
            "heading_size": "text-lg-2xl",
            "text": "<p>Reinforced hydraulic disc brake utilize pressurized fluid for heightened braking power, offering superior modulation and responsive control. With amplified finger pressure, these brakes deliver precise stopping force, ideal for challenging terrains and technical trails.<br/><br/></p>",
            "button_label": "",
            "button_link": "",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
