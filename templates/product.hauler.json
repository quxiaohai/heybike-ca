            "text_alignment_mobile": "left",
            "image": "shopify://shop_images/Brakes_d8e4c4a1-3d15-423d-80a0-395a48f5ade1.jpg",
            "image_ratio": "adapt",
            "video_url": "",
            "description": "",
            "enable_video_autoplay": false,
