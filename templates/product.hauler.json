    "faq": {
      "type": "faq",
      "blocks": {
        "question-4": {
          "type": "question",
          "disabled": true,
          "settings": {
            "title": "<strong>What is the warranty?</strong>",
            "text": "<p>The original warranty for Hauler is 1 year. If you purchase between May 20th and June 30th, 2024, we will give the bike another 1-year warranty (2 years warranty in total).</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-1": {
          "type": "question",
          "settings": {
            "title": "<strong>How to buy an Extend warranty for my e-bike?</strong>",
            "text": "<p>For orders on Heybike official website, you can extend the bike warranty at the same time you place an order or within 30 days of purchase. Please note that different plans of extended warranty need corresponding payment. You can also contact our customer service team for more details.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-2": {
          "type": "question",
          "settings": {
            "title": "<strong>What is the weight capacity of the Hauler?</strong>",
            "text": "<p>The payload capacity of Hauler is 440 lbs (including the weight of rider and cargo).</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question-3": {
          "type": "question",
          "settings": {
            "title": "<strong>What is the range of the Hauler battery?</strong>",
            "text": "<p>For Hauler with a single battery (864Wh), the max range is 55 miles; For Hauler with 2 batteries (864Wh&600Wh), the max range is 85 miles.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_BUXfbj": {
          "type": "question",
          "settings": {
            "title": "<strong>What kind of cargo can the Hauler carry?</strong>",
            "text": "<p>Hauler can carry a wide variety of cargo, including camping gear, groceries, shopping bags, and sports equipment. It can also carry your child or pet with a safety seat.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
