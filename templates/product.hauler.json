            "image_ratio": "adapt",
            "video_url": "",
            "description": "",
            "enable_video_autoplay": false,
            "enable_video_looping": false,
            "heading": "20\"x3\" Fat Tires",
            "heading_size": "text-lg-2xl",
            "text": "<p>Two fat tires provide unparalleled traction. Say goodbye to skidding and slipping. Embrace a smooth and comfortable journey. Keep riding with confidence.</p>",
