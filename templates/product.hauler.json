            "heading": "Hydraulic Disc Brakes",
            "heading_size": "text-lg-2xl",
            "text": "<p>The advanced front and rear hydraulic disc brakes provide reliable braking power for enhanced safety and control during your rides.</p>",
            "button_label": "",
            "button_link": "",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "column_qUKjhQ": {
          "type": "column",
          "settings": {
            "show_border": false,
            "text_alignment": "left",
