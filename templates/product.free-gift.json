    "product-details": {
      "type": "product-details",
      "blocks": {
        "collapsible_tab_w9zHha": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Frameset",
            "content": "<h6>Frame</h6><p>Aluminum Alloy, external removable lithium-ion battery, rear rack included, fender mounts, front & rear mount mechanical disc, kickstand mount</p><h6>Fork</h6><p>Spring Fork, 65 mm travel with preload adjustment and lock-out</p>",
            "metafields": ""
          }
        },
        "collapsible_tab_Tx7jh4": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Wheels",
            "content": "<h6>Hub rear</h6><p>Brushless geared hub motor, 80Nm, 750W/1200W Peak Motor</p><h6>Spokes</h6><p>Aluminum alloy</p><h6>Tire</h6><p>Puncture protection, 26\"x4.0\"-max tire size without fenders</p>",
            "metafields": ""
          }
        },
        "collapsible_tab_weW7dP": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "E-system & Drivetrain",
            "content": "<h6>Battery</h6><p>48V 20Ah, external removable lithium-ion battery</p><h6>Charger Port</h6><p>Output 54.6V 2.8A</p><h6>Display Type</h6><p>LCD Display</p><h6>Rear Derailleur</h6><p>Shimano 7 speed</p>",
            "metafields": ""
          }
        },
        "collapsible_tab_8UV3wm": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Accessories",
            "content": "<h6>Rear Rack</h6><p>Weight capacity: Up to 120 lbs</p><h6>Light</h6><p>LED, headlight and taillight</p><h6>Kickstand</h6><p>Alloy</p>",
            "metafields": ""
          }
        },
        "collapsible_tab_4Mk4Nz": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Weight & Dimensions",
            "content": "<h6>Weight</h6><p>35 kg / 77 lbs</p><h6>Weight limit</h6><p>This bike has a maximum total weight limit (combined weight of bicycle, rider, and cargo) of 400 pounds (181.4kg).</p><h6>Ebike Dimensions</h6><p>80*49.2*25.2 inch</p>",
