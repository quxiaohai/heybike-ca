        "text_CQqWCx": {
          "type": "text",
          "settings": {
            "padding": "0px 0px 0px 0px",
            "mb_padding": "0px 0px 0px 0px",
            "text": "<p>The Ultimate Electric Pit Bike for Big Attitudes</p>",
            "alignment": "left",
            "mb_alignment": "left",
            "style": "normal",
            "weight": 700,
            "line_height": 120,
            "pc_size": 48,
