            "param_text": "<ul><li><strong>Recommended Height:</strong> 3'9\"~6'1\"</li><li><strong>A: Handlebar Width</strong>27.6\"</li><li><strong>B: Bike Height</strong>37\"</li><li><strong>C: Min.Seat Height</strong>29.5\"</li><li><strong>D: Ground Clearance</strong>9.8\"</li><li><strong>E:Wheelbase</strong>42.5\"</li><li><strong>Max Climbing</strong>30 Degrees</li></ul>"
