    "faq_phimFf1": {
      "type": "faq",
      "blocks": {
        "question_An4mW9": {
          "type": "question",
          "settings": {
            "title": "<strong>When will my order be processed/shipped?</strong>",
            "text": "<p>Fast & Free C.A. Shipping. Electric dirt Bike orders ship from our local C.A. warehouse, typically within 2–3 business days.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_NagCNb": {
          "type": "question",
          "disabled": true,
          "settings": {
            "title": "<strong>What's included in the gift box?</strong>",
            "text": "<p>🎁 Heybike Villain Limited Gift Box Includes</p><ul><li>Villain Knit Hat</li><li>Villain Logo Magnets</li><li>Villain Keychain</li><li>Lightning Necklace</li><li>Transfer Stickers for 12 Patterns</li><li>Magnetic Phone Mount</li></ul>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_WcAwad": {
          "type": "question",
          "settings": {
            "title": "<strong>Where can I ride the Heybike Villain?</strong>",
            "text": "<p>The Heybike Villain electric dirt bike is designed for off-road use only. Always check your local laws before riding, yield to pedestrians, and obey traffic regulations.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_9GUa37": {
          "type": "question",
          "settings": {
            "title": "<strong>What rider height is suitable for the Heybike Villain electric dirt bike?</strong>",
            "text": "<p>Heybike Villain fits riders from 3.9ft (120cm) to 6.1ft (185cm). Its taller seat height combined with a slim, proportioned design supports a comfortable riding position across a wide range of rider sizes, as confirmed by real rider feedback.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_zrQbpK": {
          "type": "question",
          "settings": {
            "title": "<strong>How far can I go on a single charge?</strong>",
            "text": "<p>The 52V/26Ah lithium battery provides up to 50 miles per charge, depending on load, terrain, speed, and temperature.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_Bxjbnh": {
          "type": "question",
          "settings": {
            "title": "<strong>How long does it take to fully charge the battery?</strong>",
            "text": "<p>The Heybike Villain electric dirt bike fully charges in 4–6 hours with the 58.8 V 5 A charger, minimizing downtime between rides.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_WRJGwA": {
          "type": "question",
          "settings": {
            "title": "<strong>Does the bike support multiple speed or riding modes?</strong>",
            "text": "<p>Yes. The Heybike Villain features three adjustable riding modes, allowing you to choose the ideal balance between speed and range:<br/><br/><strong>Mode 1:</strong> 20 mph (32 km/h)<br/><strong>Mode 2:</strong> 38 mph (61 km/h)<br/><strong>Mode 3:</strong> 45 mph (72 km/h)</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_KwnWAz": {
          "type": "question",
          "settings": {
            "title": "<strong>How does R-Turn Reverse Assist improve control?</strong>",
            "text": "<p>R-Turn Reverse Assist helps you move the bike backward with ease. Simply <strong>press the R button and gently turn the throttle</strong> to engage reverse, allowing the bike to roll back smoothly. This makes <strong>tight turns, quick repositioning, and maneuvering in confined spaces</strong> much easier—without having to push or lift the bike.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_pJiJUK": {
          "type": "question",
          "settings": {
            "title": "<strong>Is the battery removable?</strong>",
            "text": "<p>Yes. The battery is removable, but you don’t need to take it out to charge. Simply plug the charger into the bike for easy on-bike charging. You can also remove the battery and charge it separately if preferred.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },
