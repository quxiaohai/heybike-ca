    "mc_multicolumn_card_slide_EFD32": {
      "type": "mc_multicolumn-card-slide",
      "blocks": {
        "card_JkdVbz": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Heybike_Villain_Riders_Height_Recommendation.jpg",
            "mb_image": "shopify://shop_images/Heybike_Villain_Riders_Height_Recommendation.jpg",
            "title": "Fits Riders of All Sizes",
            "text": "<p>Heybike Villain features a taller 29.5\" seat height and a slim, ergonomic frame, designed to provide a natural, comfortable riding position for riders from 3.9ft to 6.1ft—no cramped posture, no size limits.</p>"
          }
        },
        "card_CbxQdj": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Motor_Feature_Highlights.png",
            "title": "4160W Mid-Drive Motor",
            "text": "<p>With 190N·m of torque and a 52V peak output, Heybike Villain outclasses standard 2kW pit bikes, delivering explosive acceleration, sharper control, and a ride that feels alive—just like a high-end gas dirt bike.</p>"
          }
        },
        "card_kK7qXg": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Battery_Feature_Highlights.png",
            "title": "52V 26Ah Large Battery",
            "text": "<p>With a high-capacity 52V 26Ah battery and rapid 58.8V 5A charger, Heybike Villain powers longer rides (up to 50 miles) and charges faster than most dirt bikes, keeping you ahead on every trail.</p>"
          }
        },
        "card2": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Full_Suspension_Air_Shock_Absorber_Feature_Highlights.png",
            "title": "Nitrogen Rear Air Shock",
            "text": "<p>The rear air shock reduces high-frequency vibration, easing hand and body fatigue while keeping the ride smooth on gravel and uneven ground.</p>"
          }
        },
        "card_hmNYAE": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Far_Drive_Controller_Feature_Highlights.png",
            "title": "FarDriver Smart Controller",
            "text": "<p>FarDriver controller delivers high-current punch with full App tuning — adjust throttle response, power ramp, regen, and even set or limit top speed to match your riding style, from smooth control to hard launch.</p>"
          }
        },
        "card_GUtxyx": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_R_Return_Feature_Highlights.png",
            "title": "R-Turn Reverse Assist",
            "text": "<p>Press the R and turn throttle to reverse. Effortless rollback, making tight turns and quick repositioning easy.</p>"
          }
        },
        "card_qmFBkC": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Fat_Tire_Feature_Highlights.png",
            "title": "Puncture-Resistant Fat Tires",
            "text": "<p>Wide 14″ front and 12″ rear fat tires deliver extra grip and stability, helping you stay balanced during wheelies and confident on dirt, street, or rough ground</p>"
          }
        },
        "card3": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Hydraulic_Front_Suspension_Feature_Highlights.png",
            "title": "Hydraulic Front Suspension",
            "text": "<p>Designed to handle deep bumps and hard landings, long travel keeps the ride composed, stable, and refined at speed.</p>"
          }
        },
        "card_Em9gqN": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Throttle_Feature_Highlights.png",
            "title": "Regenerative Braking System(RBS)",
            "text": "<p>Throttle off, energy back: Villain’s regenerative braking preserves power and control, so every ride stays sharp and responsive—even during tricks and landings.</p>"
          }
        },
        "card4": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_LED_Display_Feature_Highlights.png",
            "title": "LED Display",
            "text": "<p>A bright, high-contrast LED display keeps key ride data clear in any light.</p>"
          }
        },
        "card5": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Tilt_Protection_Feature_Highlights.png",
            "title": "Magnetic Emergency Switch",
            "text": "<p>A magnetic emergency switch kills the power the moment you fall or step away. Perfect for new riders, tight spots, and real-world sketchy moments.</p>"
          }
        },
        "card_8CJBph": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Villain_Electric_Dirt_Bike_Hydraulic_Disc_Brakes_Feature_Highlights.png",
            "title": "Heavy-Duty Hydraulic Brakes",
            "text": "<p>4mm thick brake rotors deliver strong, consistent stopping power, giving you confident control on dirt, pavement, and fast downhill runs.</p>"
          }
        },
        "card_jUG9Q6": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/Heybike_Villain_Front_Light.jpg",
            "title": "Own The Night",
            "text": "<p>A factory-equipped LED headlight keeps the ride going after sunset. Bright and wide for streets and side paths, it lets the crew roll together after dark with clear visibility and extra confidence — the same routes and the same chaos, just later in the day.</p>"
          }
        }
      },
