        },
        "text_AbGyqF": {
          "type": "text",
          "settings": {
            "padding": "0px 0px 0px 0px",
            "mb_padding": "20px 0px 0px 0px",
            "text": "<p>Heybike Villain is a 14/12-inch electric dirt bike built for the bold, style-driven new generation.<br/>It blends strong power, long-range capability, and responsive control, making it ideal for group rides, city open spaces, backyard fun, and trails.<br/><br/>It delivers real dirt-bike attitude in a compact, confidence-boosting package. More than a bike, Villain is a symbol of identity—loud energy, fearless fun, and a way for the young to stand out, connect, and express who they are.</p>",
            "alignment": "left",
            "mb_alignment": "left",
            "style": "normal",
            "weight": 400,
            "line_height": 120,
            "pc_size": 18,
            "mb_size": 14,
            "width": 55,
            "mb_width": 100,
            "color": "#cdcdcd",
            "bold_color": "#ffffff",
            "gradient_color": ""
          }
        }
      },
