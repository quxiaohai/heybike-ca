{%- assign ss = section.settings -%}
<style>
    .mc_media-scene-slide {
        background: #ffffff;
        padding: 60px 0;
    }

    .mc_media-scene-slide .slide-wrapper {
        aspect-ratio: 2.5;
    }

    .mc_media-scene-slide .slide-media {
        border-radius: 20px;
        background: #f8f9fd;
    }

    .mc_media-scene-slide .slide-media .video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .mc_media-scene-slide .slide-tabs {
        gap: 8px;
        position: absolute;
        left: 48px;
        top: 50%;
        transform: translateY(-50%);
        z-index: 2;
        width: min(220px, 100% - 40px);
    }

    .mc_media-scene-slide .slide-tab {
        appearance: none;
        background: rgba(0, 0, 0, 0.3);
        color: #ECEDF0;
        border: none;
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 12px;
        transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    }

    .mc_media-scene-slide .slide-tab:hover {
        transform: translateX(10px);
    }

    .mc_media-scene-slide .slide-tab.active {
        color: #000000;
        background: #FFFFFF;
    }

    .mc_media-scene-slide .video-cta {
        width: 36px;
        height: 36px;
        position: absolute;
        right: 40px;
        bottom: 40px;
        border: 0;
        background: rgba(137, 137, 137, 0.48);
        backdrop-filter: blur(24px);
        color: #fff;
        z-index: 2;
        transition: background 0.2s ease, color 0.2s ease;
    }

    .mc_media-scene-slide .video-cta:hover {
        background: #FFFFFF;
        color: #000000;
    }

    .mc_media-scene-slide .video-cta .icon {
        width: 50%;
        height: 50%;
    }

    .mc_media-scene-slide .video-cta .icon-pause {
        display: none;
    }

    .mc_media-scene-slide .video-cta.playing .icon-pause {
        display: block;
    }

    .mc_media-scene-slide .video-cta.playing .icon-play {
        display: none;
    }

    .mc_media-scene-slide .media-mark {
        position: absolute;
        top: 48px;
        right: 48px;
        z-index: 2;
    }

    .mc_media-scene-slide .media-mark .image {
        height: 24px;
        width: auto;
        object-fit: contain;
    }

    @media screen and (max-width: 1023px) {
        .mc_media-scene-slide {
            padding: 1.875rem 0;
        }

        .mc_media-scene-slide .slide-wrapper {
            display: flex;
            flex-direction: column-reverse;
            gap: 1rem;
            aspect-ratio: auto;
        }

        .mc_media-scene-slide .slide-media {
            aspect-ratio: 4/3;
            border-radius: 1.25rem;
            height: auto;
        }

        .mc_media-scene-slide .slide-tabs {
            gap: 0.5rem;
            position: static;
            transform: translateY(0);
            width: auto;
            display: grid;
            grid-template-columns: 1fr 1fr;
            align-content: start;
        }

        .mc_media-scene-slide .slide-tab {
            background: #F8F9FD;
            color: #000000;
            padding: 0.5rem 0;
            justify-content: center;
        }

        .mc_media-scene-slide .slide-tab .text {
            line-height: 1.2 !important;
        }

        .mc_media-scene-slide .slide-tab:hover {
            transform: translateX(0);
        }

        .mc_media-scene-slide .slide-tab.active {
            color: #FFFFFF;
            background: #262626;
        }

        .mc_media-scene-slide .slide-tab .tab-icon {
            display: none;
        }

        .mc_media-scene-slide .video-cta {
            right: 16px;
            bottom: 16px;
        }

        .mc_media-scene-slide .media-mark {
            top: 1.75rem;
            right: 1.75rem;
        }

        .mc_media-scene-slide .media-mark .image {
            height: 0.875rem;
        }
    }

    {% render 'page-wrap-style' %}
</style>
<div class="mc_media-scene-slide section--page" id="{{ section.id }}-slide">
    {%- render 'section-title', info: ss -%}
    <div class="slide-content w-full page-width">
        <div class="slide-wrapper relative w-full">
            <tab-panel node-name="panel" class="slide-tabs flex-column">
                {%- for block in section.blocks -%}
                    {%- assign bs = block.settings -%}
                    <button
                        node-name="tab"
                        data-proxy="tab"
                        data-index="{{ forloop.index0 }}"
                        class="slide-tab lh-2 flex-between{% if forloop.first %} active{% endif %}" type="button">
                        <span class="text">{{ bs.title }}</span>
                        <span class="tab-icon flex-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20"
                                 fill="none">
                                <path
                                    d="M10.0013 18.3332C14.6037 18.3332 18.3346 14.6022 18.3346 9.99984C18.3346 5.39746 14.6037 1.6665 10.0013 1.6665C5.39893 1.6665 1.66797 5.39746 1.66797 9.99984C1.66797 14.6022 5.39893 18.3332 10.0013 18.3332Z"
                                    stroke="currentColor"
                                    stroke-width="1.66667"
                                    stroke-linejoin="round"
                                ></path>
                                <path d="M10 6.6665V13.3332" stroke="currentColor" stroke-width="1.66667"
                                      stroke-linecap="round" stroke-linejoin="round"></path>
                                <path d="M6.66797 10H13.3346" stroke="currentColor" stroke-width="1.66667"
                                      stroke-linecap="round" stroke-linejoin="round"></path>
                            </svg>
                        </span>
                    </button>
                {%- endfor -%}
            </tab-panel>
            {%- for block in section.blocks -%}
                {%- assign bs = block.settings -%}
                {%- if forloop.first -%}
                    <div class="slide-media overflow-hidden w-full h-full relative">
                        {%- assign video_mobile = bs.video_mobile | default: bs.video_desktop -%}
                        {%- render 'global-video',
                            desktop_video: bs.video_desktop,
                            desktop_cover: bs.desktop_image,
                            desktop_default_class: 'desktop-done w-full h-full',
                            desktop_size: 1400,
                            desktop_node: 'pc_video',
                            mobile_video: video_mobile,
                            mobile_cover: bs.mobile_image,
                            mobile_default_class: 'mobile-done w-full h-full',
                            mobile_size: 700,
                            mobile_node: 'mb_video',
                            loop: true,
                            frament: true,
                            source: false
                        -%}
                        <button node-name="play" class="video-cta flex-center absolute rounded-full" type="button"
                                data-video-toggle="" aria-label="Pause video">
                            <svg class="icon icon-play" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M8.5 6.5L18 12L8.5 17.5V6.5Z" fill="currentColor"></path>
                            </svg>
                            <svg class="icon icon-pause" viewBox="0 0 24 24" aria-hidden="true">
                                <path d="M8 6H11V18H8V6ZM13 6H16V18H13V6Z" fill="currentColor"></path>
                            </svg>
                        </button>
                        {%- if ss.mark != blank -%}
                            <div class="media-mark">
                                {%- render 'global-image', image: ss.mark, image_size: 400 -%}
                            </div>
                        {%- endif -%}
                    </div>
                {%- endif -%}
            {%- endfor -%}
        </div>
    </div>
</div>
<script>
    $heybike.ready(() => {
        const videoList = [
            {%- for block in section.blocks -%}
            {%- assign bs = block.settings -%}
            {%- assign video_mobile = bs.video_mobile | default: bs.video_desktop -%}
            {
                "pc_url": "{%- render 'video-url', video: bs.video_desktop -%}",
                "pc_cover": "{{ bs.desktop_image | default: bs.video_desktop | image_url: width: 1400 }}",
                "mb_url": "{%- render 'video-url', video: video_mobile -%}",
                "mb_cover": "{{ bs.mobile_image | default: video_mobile | image_url: width: 700 }}",
            }{% if forloop.last == false %},{% endif %}
            {%- endfor -%}
        ]
        const node = document.getElementById('{{ section.id }}-slide');
        let nodeList = $heybike.getNodeList(node);
        let current = 0;
        const onResetTemp = (key) => {
            const elem = nodeList[`${key}_video`];
            if (elem?.tagName.toLocaleUpperCase() !== 'video') {
                const templateElement = elem.querySelector(`template`);
                if (templateElement) {
                    const media = templateElement.content.firstElementChild.cloneNode(true);
                    elem.replaceWith(media);
                    nodeList[`${key}_video`] = media;
                }
            }
        }
        const onPlay = () => {
            const key = $heybike.isMobile ? 'mb' : 'pc';
            onPause();
            nodeList[`${key}_video`].src = videoList[current][`${key}_url`];
            nodeList[`${key}_video`].poster = videoList[current][`${key}_cover`];
            nodeList[`${key}_video`]?.play().then(() => {
                nodeList.play.classList.add('playing');
            });
        }
        const onPause = () => {
            const key = $heybike.isMobile ? 'mb' : 'pc';
            onResetTemp(key);
            nodeList[`${key}_video`]?.pause();
            nodeList.play.classList.remove('playing');
        }

        $heybike.inView(node, () => {
            onPlay();
            return () => onPause();
        });

        nodeList.play.addEventListener('click', () => {
            if (nodeList.play.classList.contains('playing')) {
                onPause();
            } else {
                onPlay();
            }
        });

        nodeList.panel.addEventListener('slider:change', ({detail}) => {
            current = detail.index;
            onPlay();
        });
    });
</script>
{% schema %}
{
  "name": "MC Media Scene Slide",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Media Scene Slide"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "Desktop padding Bottom"
    },
    {
      "type": "number",
      "id": "mb_page_bottom",
      "label": "Mobile padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": false
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "Title font style",
      "options": [
        {
          "label": "Normal",
          "value": "normal"
        },
        {
          "label": "italic",
          "value": "italic"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "title_bold_color",
      "label": "Title Bold color",
      "default": "#000000"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "mark",
      "label": "Mark"
    }
  ],
  "blocks": [
    {
      "type": "media",
      "name": "Media",
      "settings": [
        {
          "type": "video",
          "id": "video_desktop",
          "label": "Video (Desktop)"
        },
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop video cover"
        },
        {
          "type": "video",
          "id": "video_mobile",
          "label": "Video (Mobile)"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile video cover"
        },
        {
          "type": "checkbox",
          "id": "muted",
          "label": "Disable muted",
          "default": true
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    }
  ]
}
{% endschema %}