{%- liquid
    assign cid = section.id | split: '__' | last
    assign ss = section.settings
    assign is_row = false
    if ss.layout == 'row'
        assign is_row = true
    endif
    assign is_mb_row = false
    if ss.mb_layout == 'row'
        assign is_mb_row = true
    endif
-%}
<style>

    .{{ cid }} {
        justify-content: {% if is_row %}space-between{% else %}flex-start{% endif %};
        align-items: {% if is_row %}center{% else %}flex-start{% endif %};
        flex-direction: {% if is_row %}row{% else %}column{% endif %};
    }

    {%- for block in section.blocks -%}
    {%- liquid
        assign index = forloop.index
        assign bs = block.settings
    -%}
    .{{ cid }} .sec-text-{{ index }} {
        font-size: {{ bs.pc_size }}px;
        padding: {{ bs.padding }};
        font-weight: {{ bs.weight }};
        font-style: {{ bs.style }};
        text-align: {{ bs.alignment }};
        width: {{ bs.width }}%;
        line-height: {{ bs.line_height | divided_by: 100.0 }};
    }

    .{{ cid }} .sec-text-{{ index }} strong {
        color: {{ bs.bold_color }};
    }

    {%- endfor -%}
    @media screen and (max-width: 1440px) {
    {%- for block in section.blocks -%}
    {%- liquid
        assign index = forloop.index
        assign bs = block.settings
        assign size = bs.pc_size | times: 0.85
        if size < 12
        assign size = 12
        endif
    -%}
        .{{ cid }} .sec-text-{{ index }} {
            font-size: {{ size }}px;
        }

    {%- endfor -%}
    }

    @media screen and (max-width: 1023px) {
        .{{ cid }} {
            justify-content: {% if is_mb_row %}space-between{% else %}flex-start{% endif %};
            align-items: {% if is_mb_row %}center{% else %}flex-start{% endif %};
            flex-direction: {% if is_mb_row %}row{% else %}column{% endif %};
        }

    {%- for block in section.blocks -%}
    {%- liquid
        assign index = forloop.index
        assign bs = block.settings
    -%}
        .{{ cid }} .sec-text-{{ index }} {
            font-size: {{ bs.mb_size }}px;
            padding: {{ bs.mb_padding }};
            width: {{ bs.mb_width }}%;
            text-align: {{ bs.mb_alignment }};
        }

    {%- endfor -%}
    }

    {% render 'page-wrap-style' %}
</style>
<div class="{{ cid }} flex section--page page-width">
    {%- for block in section.blocks -%}
        {%- assign bs = block.settings -%}
        <div class="sec-text-{{ forloop.index }}{% if bs.gradient_color != blank %} text-gradient{% endif %}"
             style="{% if info.title_gradient_color != blank %}--background: {{ info.title_color.rgb }}; --gradient: {{ bs.gradient_color }};{% else %}color: {{ bs.color }};{% endif %}">
            {{ bs.text }}
        </div>
    {%- endfor -%}
</div>
{% schema %}
{
  "name": "MC Section Text",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Section Text"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Desktop layout show",
      "options": [
        {
          "label": "Column",
          "value": "column"
        },
        {
          "label": "Row",
          "value": "row"
        }
      ],
      "default": "column"
    },
    {
      "type": "select",
      "id": "mb_layout",
      "label": "Mobile layout show",
      "options": [
        {
          "label": "Column",
          "value": "column"
        },
        {
          "label": "Row",
          "value": "row"
        }
      ],
      "default": "column"
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        {
          "type": "text",
          "id": "padding",
          "label": "Desktop padding",
          "default": "0px 0px 0px 0px",
          "info": "Up, Right, Down, Left -> (10px 0px 10px 0px)"
        },
        {
          "type": "text",
          "id": "mb_padding",
          "label": "Mobile padding",
          "default": "0px 0px 0px 0px",
          "info": "Up, Right, Down, Left -> (10px 0px 10px 0px)"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text"
        },
        {
          "type": "text_alignment",
          "id": "alignment",
          "label": "Desktop text alignment",
          "default": "center"
        },
        {
          "type": "text_alignment",
          "id": "mb_alignment",
          "label": "Mobile text alignment",
          "default": "center"
        },
        {
          "type": "select",
          "id": "style",
          "label": "Font style",
          "options": [
            {
              "label": "Normal",
              "value": "normal"
            },
            {
              "label": "italic",
              "value": "italic"
            }
          ],
          "default": "normal"
        },
        {
          "type": "range",
          "id": "weight",
          "label": "Text weight",
          "min": 200,
          "max": 900,
          "step": 100,
          "unit": "w",
          "default": 400
        },
        {
          "type": "range",
          "id": "line_height",
          "label": "Text line weight",
          "min": 100,
          "max": 500,
          "step": 10,
          "unit": "%",
          "default": 120
        },
        {
          "type": "range",
          "id": "pc_size",
          "label": "Desktop text size",
          "min": 12,
          "max": 100,
          "step": 1,
          "unit": "px",
          "default": 18
        },
        {
          "type": "range",
          "id": "mb_size",
          "label": "Mobile text size",
          "min": 6,
          "max": 100,
          "step": 1,
          "unit": "px",
          "default": 14
        },
        {
          "type": "range",
          "id": "width",
          "label": "Desktop width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 100
        },
        {
          "type": "range",
          "id": "mb_width",
          "label": "Mobile width",
          "min": 10,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 100
        },
        {
          "type": "color",
          "id": "color",
          "label": "Color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "bold_color",
          "label": "Bold color",
          "default": "#ffffff"
        },
        {
          "type": "color_background",
          "id": "gradient_color",
          "label": "Gradient color"
        }
      ]
    }
  ]
}
{% endschema %}