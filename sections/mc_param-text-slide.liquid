{%- liquid
    assign ss = section.settings
    assign cid = section.id | split: '__' | last
-%}
<style>
    .mc_param-text-slide {
        padding: 80px 0;
        background: #000000;
        position: relative;
    }

    .mc_param-text-slide .backdrop-image {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
    }

    .{{ cid }}-section--title {
        position: relative;
        z-index: 2;
    }

    .mc_param-text-slide .text-content {
        position: relative;
        z-index: 1;
        width: 100%;
    }

    .mc_param-text-slide .text-content .slide-tabs {
        padding-bottom: 86px;
        position: relative;
        z-index: 2;
    }

    .mc_param-text-slide .text-content .slide-tabs .button-incline {
        --button-color: {{ ss.tab_color }};
        --button-background-color: {{ ss.tab_bg_color }};
    }

    .mc_param-text-slide .text-content .slide-tabs .button-incline.active {
        --button-background-color: {{ ss.tab_active_bg_color }};
        --button-color: {{ ss.tab_active_color }};
    }

    .mc_param-text-slide .text-content .card-item {
        width: 100%;
        height: auto;
        display: none;
    }

    .mc_param-text-slide .text-content .card-item.active {
        display: flex;
    }

    .mc_param-text-slide .text-content .card-item .info-wrap {
        width: 43%;
    }

    .mc_param-text-slide .text-content .card-item .info-wrap ul {
        list-style: none;
    }

    .mc_param-text-slide .text-content .card-item .info-wrap ul li {
        color: {{ ss.param_text_color }};
        display: flex;
        line-height: 1.2;
        padding: 14px 0;
        font-size: {{ ss.param_text_size }}px;
        border-bottom: 1px solid{{ ss.border_color }};
        white-space: nowrap;
    }

    .mc_param-text-slide .text-content .card-item .info-wrap ul li strong {
        width: 15.42vw;
        max-width: 291px;
        font-weight: 700;
    }

    .mc_param-text-slide .text-content .card-item .media-wrap {
        width: 57%;
        aspect-ratio: var(--image-ratio);
    }

    .mc_param-text-slide .text-content .card-item .media-wrap.fill {
        width: 100%;
        aspect-ratio: auto;
    }

    .mc_param-text-slide .text-content .card-item .media-wrap.fill .media {
        aspect-ratio: var(--aspect-ratio);
    }

    .mc_param-text-slide .text-content .card-item .media-wrap .image {
        object-fit: contain;
    }

    @media screen and (max-width: 1440px) {
        .mc_param-text-slide {
            padding: 72px 0;
        }

        .mc_param-text-slide .text-content .slide-tabs {
            padding-bottom: 77px;
        }

        .mc_param-text-slide .text-content .card-item .info-wrap ul li {
            padding: 13px 0;
            font-size: {{ ss.param_text_size | times: 0.9 | round }}px;
        }
    }

    @media screen and (max-width: 1023px) {
        .mc_param-text-slide {
            padding: 2.5rem 0;
        }

        .mc_param-text-slide .text-content .slide-tabs {
            padding-bottom: 0.625rem;
            overflow-x: auto;
            white-space: nowrap;
        }

        .mc_param-text-slide .text-content .card-item {
            flex-direction: column;
            background-color: {{ ss.card_bg_color }};
            padding: 0 0.9375rem;
        }

        .mc_param-text-slide .text-content .card-item .backdrop-image {
            top: auto;
            bottom: 0;
            height: auto;
            object-fit: contain;
        }

        .mc_param-text-slide .text-content .card-item .info-wrap {
            width: 100%;
            padding: 0.625rem 0.3125rem;
        }

        .mc_param-text-slide .text-content .card-item .info-wrap ul {
            width: 100%;
        }

        .mc_param-text-slide .text-content .card-item .info-wrap ul li {
            font-size: {{ ss.mb_param_text_size }}px;
            padding: 0.4375rem 0;
        }

        .mc_param-text-slide .text-content .card-item .info-wrap ul li strong {
            width: 37.4358974359vw;
        }

        .mc_param-text-slide .text-content .card-item .media-wrap {
            margin-top: 1rem;
            width: 100%;
        }
        .mc_param-text-slide .text-content .card-item .media-wrap.fill .media {
            aspect-ratio: var(--mb-aspect-ratio);
        }
    }

    {% render 'page-wrap-style' %}
</style>
<div class="mc_param-text-slide section--page w-full" id="{{ section.id }}-slide">
    {%- render 'section-title', info: ss -%}
    {%- if ss.pc_image != blank -%}
        {%- render 'global-image',
            image: ss.pc_image,
            class: 'desktop-done backdrop-image'
        -%}
    {%- endif -%}
    <div class="text-content page-width">
        {%- if section.blocks.size > 1 -%}
            <div class="slide-tabs hide-scroll-bar flex-left">
                {%- for block in section.blocks -%}
                    {%- assign bs = block.settings -%}
                    <button is="magnet-button"
                            data-proxy="tab"
                            node-name="tab"
                            data-index="{{ forloop.index0 }}"
                            class="button-incline flex-center relative {% if forloop.first %}active{% endif %}">
                        <span class="btn-text">{{ bs.title }}</span>
                    </button>
                {%- endfor -%}
            </div>
        {%- endif -%}
        {%- for block in section.blocks -%}
            {%- assign bs = block.settings -%}
            <animate-element node-name="panel"
                             data-repeat
                             class="card-item{% if forloop.first %} active{% endif %} relative flex-between">
                {%- if ss.mb_image != blank -%}
                    {%- render 'global-image',
                        image: ss.mb_image,
                        class: 'mobile-done backdrop-image'
                    -%}
                {%- endif -%}
                {%- if bs.param_text != blank -%}
                    <div class="info-wrap flex-left relative">
                        {{ bs.param_text }}
                    </div>
                {%- endif -%}
                {%- liquid
                    assign width = 900
                    assign image_ratio = '5/3'
                    assign show_size = false
                    if bs.param_text == blank
                        assign width = 1440
                        assign show_size = true
                    endif
                    if bs.image_ratio != blank
                        assign image_ratio = bs.image_ratio
                    endif
                -%}
                <div class="media-wrap {% if bs.param_text == blank %}fill{% endif %} relative"
                     style="--image-ratio: {{ image_ratio }};">
                    {%- render 'global-image',
                        desktop_img: bs.pc_image,
                        desktop_size: width,
                        mobile_img: bs.mb_image,
                        mobile_size: 750,
                        show_size: show_size
                    -%}
                </div>
            </animate-element>
        {%- endfor -%}
    </div>
</div>
{%- if section.blocks.size > 1 -%}
    <script>
        $heybike.tabSwitch({
            root: document.getElementById('{{ section.id }}-slide'),
            device: 'mobile'
        });
    </script>
{%- endif -%}
{% schema %}
{
  "name": "MC Param Text Slide",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Param Text Slide"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color"
    },
    {
      "type": "image_picker",
      "id": "pc_image",
      "label": "Desktop backdrop image"
    },
    {
      "type": "image_picker",
      "id": "mb_image",
      "label": "Mobile backdrop image"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": false
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "Title font style",
      "options": [
        {
          "label": "Normal",
          "value": "normal"
        },
        {
          "label": "italic",
          "value": "italic"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_bold_color",
      "label": "Title Bold color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Slide tab"
    },
    {
      "type": "color",
      "id": "tab_color",
      "label": "Tab text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "tab_active_color",
      "label": "Tab active text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "tab_bg_color",
      "label": "Tab background color",
      "default": "#df1cf1"
    },
    {
      "type": "color",
      "id": "tab_active_bg_color",
      "label": "Tab active background color",
      "default": "#f8e737"
    },
    {
      "type": "header",
      "content": "Slide card"
    },
    {
      "type": "range",
      "id": "param_text_size",
      "label": "Desktop param text size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "mb_param_text_size",
      "label": "Mobile param text size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 9
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Mobile card background color",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "param_text_color",
      "label": "Param text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border color",
      "default": "#383838"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Tab title"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mb_image",
          "label": "Mobile image"
        },
        {
          "type": "text",
          "id": "image_ratio",
          "label": "Image ratio(w/h)",
          "default": "5/3"
        },
        {
          "type": "richtext",
          "id": "param_text",
          "label": "Param text",
          "default": "<ul><li><strong>Motor</strong>52V 4160W Mid Drive Motor</li></ul>"
        }
      ]
    }
  ]
}
{% endschema %}
